{
  "$schema": "https://schema.agentcore.aws.dev/v1/agentcore.json",
  "name": "AdmissionAgent",
  "version": 1,
  "managedBy": "CDK",
  "tags": {
    "agentcore:created-by": "agentcore-cli",
    "agentcore:project-name": "AdmissionAgent"
  },
  "runtimes": [
    {
      "name": "AdmissionAgent",
      "build": "Container",
      "entrypoint": "main.py",
      "codeLocation": "app/AdmissionAgent/",
      "runtimeVersion": "PYTHON_3_14",
      "envVars": [
        {
          "name": "KNOWLEDGE_BASE_ID",
          "value": "JPKFFQEAGB"
        },
        {
          "name": "ATHENA_LAMBDA_NAME",
          "value": "education-athena-query"
        },
        {
          "name": "AWS_DEFAULT_REGION",
          "value": "us-east-1"
        },
        { "name": "ADVISOR_MCP_URL", "value": "https://admissionagent-education-advisor-gateway-wutrl7bgbo.gateway.bedrock-agentcore.us-east-1.amazonaws.com/mcp" }
      ],
      "networkMode": "PUBLIC",
      "protocol": "HTTP",
      "executionRoleArn": "arn:aws:iam::463470941747:role/agentcore-agent-role"
    }
  ],
  "memories": [
    {
      "name": "admission_agent_memory",
      "eventExpiryDuration": 30,
      "strategies": [
        {
          "type": "SEMANTIC",
          "namespaces": [
            "/users/{actorId}/facts"
          ]
        },
        {
          "type": "USER_PREFERENCE",
          "namespaces": [
            "/users/{actorId}/preferences"
          ]
        }
      ]
    }
  ],
  "credentials": [],
  "evaluators": [],
  "onlineEvalConfigs": [],
  "agentCoreGateways": [
    {
      "name": "education-advisor-gateway",
      "description": "Gateway for education-advisor-gateway",
      "targets": [
        {
          "name": "advisor-requests",
          "targetType": "lambdaFunctionArn",
          "lambdaFunctionArn": {
            "lambdaArn": "arn:aws:lambda:us-east-1:463470941747:function:education-advisor-requests",
            "toolSchemaFile": "/workshop/mcp/tools.json"
          }
        }
      ],
      "authorizerType": "NONE",
      "enableSemanticSearch": true,
      "exceptionLevel": "NONE"
    }
  ],
  "policyEngines": []
}